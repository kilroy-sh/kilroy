# Required: random secret for signing sessions and JWTs.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL where your Kilroy is reachable — used for OAuth callbacks and
# MCP audiences. Set this if you're behind a reverse proxy or using a custom
# domain. If unset, defaults to http://localhost:${KILROY_PORT}.
# KILROY_URL=https://kilroy.sh

# Port the server listens on internally, and the host port compose
# publishes it on. Default: 7432. Separate from KILROY_URL — a reverse
# proxy forwards a public URL (no port) to this internal port. Only
# shows up in the URL when KILROY_URL is unset.
# KILROY_PORT=7432

# Pin a specific Kilroy version. Default: the tag baked into docker-compose.yml.
# KILROY_REF=v0.16.0

# Disable email+password login. Default: true (enabled).
# Set to "false" on instances that should require OAuth only.
# KILROY_EMAIL_PASSWORD=false

# OAuth providers (optional) — enable GitHub/Google login for humans.
# A social button only appears if BOTH id and secret are set for that provider.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Object storage ──────────────────────────────────────────────────
# Kilroy stores attached files (images, CSVs, etc.) in a project-scoped
# object store. By default, bytes live in Postgres bytea (zero extra ops).
#
# To use AWS S3 for new uploads instead, set BOTH KILROY_S3_BUCKET and
# KILROY_S3_PREFIX. Existing objects continue to serve from wherever they
# were originally written (per-object storage_backend column), so the
# switch is safe at any time and does not require a data migration.
#
# When KILROY_S3_BUCKET is set, the standard AWS SDK env chain is used
# for credentials and region: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# AWS_REGION (or AWS_PROFILE / IAM-role-based auth in cloud deployments).
#
# Note: only AWS S3 proper is supported in v1. R2 / MinIO / other
# S3-compatible endpoints are NOT supported.
#
# KILROY_S3_BUCKET=my-kilroy-objects
# KILROY_S3_PREFIX=kilroy/objects     # REQUIRED when KILROY_S3_BUCKET is set
